# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_URI=mongodb://localhost:27017/khalifa-crafted

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a verified sender domain in Resend
EMAIL_FROM=noreply@khalifacrafted.store

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_random_secret_here
# The public URL of this backend (used by Better Auth for redirects)
BETTER_AUTH_URL=https://api.khalifacrafted.store
